# Secure Proxy Manager — Environment Configuration
# Copy to .env and edit before starting: cp .env.example .env
# Or use the installer: bash deploy/install.sh (auto-generates credentials)

# ==============================================================================
# AUTHENTICATION (required)
# ==============================================================================
# ⚠️  CHANGE THESE — containers will crash if empty!
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=changeme

# JWT secret — auto-generates if empty (sessions lost on restart)
SECRET_KEY=

# ==============================================================================
# HTTPS / TLS
# ==============================================================================
# Self-signed cert is generated automatically. For real certs:
# LETSENCRYPT_DOMAIN=proxy.example.com
# LETSENCRYPT_EMAIL=admin@example.com
LETSENCRYPT_DOMAIN=
LETSENCRYPT_EMAIL=

# CORS — include your domain if using Let's Encrypt
CORS_ALLOWED_ORIGINS=https://localhost:8443

# ==============================================================================
# NETWORK
# ==============================================================================
# Backend URL (internal Docker network — don't change unless customizing)
BACKEND_URL=http://backend:5000

# Squid proxy settings
PROXY_HOST=proxy
PROXY_PORT=3128
PROXY_CONTAINER_NAME=secure-proxy-manager-proxy

# Your LAN IP — enables WPAD auto-proxy discovery for browsers
# PROXY_IP=192.168.1.100
PROXY_IP=

# ==============================================================================
# WAF
# ==============================================================================
# Anomaly score threshold (lower = stricter). Default: 10
# WAF_BLOCK_THRESHOLD=10

# Comma-separated categories to disable (e.g. DEBUG_LEAK,RESPONSE_ANOMALY)
WAF_DISABLED_CATEGORIES=

# Heuristic toggles (all default to env value or Settings UI)
# WAF_H_ENTROPY=true
# WAF_H_BEACONING=true
# WAF_H_PII=false
# WAF_H_SHARDING=false
# WAF_H_MORPHING=false
# WAF_H_GHOSTING=false

# ==============================================================================
# DNS
# ==============================================================================
# Upstream DNS resolvers (defaults: malware-blocking)
DNS_UPSTREAM_1=1.1.1.3
DNS_UPSTREAM_2=9.9.9.9
DNS_UPSTREAM_3=8.8.8.8

# ==============================================================================
# OPTIONAL SERVICES
# ==============================================================================
# Tailscale auth key (get from https://login.tailscale.com/admin/settings/keys)
# TAILSCALE_AUTHKEY=tskey-auth-...

# API request timeout (seconds)
REQUEST_TIMEOUT=120
