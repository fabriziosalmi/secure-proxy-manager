# Secure Proxy Manager - Environment Configuration
# Copy this file to .env and fill in your values before starting.
# Running without these set will cause the services to refuse to start.

# ==============================================================================
# AUTHENTICATION CREDENTIALS (required)
# ==============================================================================
# Used for Web UI login, API, and inter-service authentication.
# Must be set to non-empty, non-default values.

BASIC_AUTH_USERNAME=
BASIC_AUTH_PASSWORD=

# ==============================================================================
# SECURITY CONFIGURATION
# ==============================================================================
# Session key for the Flask UI proxy.
# Auto-generates on startup if empty (sessions do not persist across restarts).
# Set explicitly for stable sessions: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ==============================================================================
# CORS CONFIGURATION
# ==============================================================================
# Comma-separated list of allowed origins for the backend API.
# Must include both the external UI URL and the Docker-internal service name.
CORS_ALLOWED_ORIGINS=http://localhost:8011,http://web:8011

# ==============================================================================
# BACKEND API CONFIGURATION
# ==============================================================================
# Backend URL as seen by the Flask UI proxy container (internal Docker network).
BACKEND_URL=http://backend:5000

# API request timeout in seconds
REQUEST_TIMEOUT=30

# Maximum number of API retry attempts
MAX_RETRIES=5

# Exponential backoff factor for retries
BACKOFF_FACTOR=1.0

# Wait time after startup before the UI proxy attempts to connect (seconds)
RETRY_WAIT_AFTER_STARTUP=10

# ==============================================================================
# PROXY SERVICE CONFIGURATION
# ==============================================================================
# Squid container hostname (Docker service name)
PROXY_HOST=proxy

# Squid proxy port
PROXY_PORT=3128

# Squid Docker container name — used to send reconfigure signals after rule changes.
# Must match the container_name in docker-compose.yml.
PROXY_CONTAINER_NAME=secure-proxy-manager-proxy

# ==============================================================================
# NOTES
# ==============================================================================
# - Rename this file to .env after editing
# - Restart services after changes: docker-compose restart
# - Never commit .env to version control
# - Port 5001 (backend WebSocket) should be firewalled from the internet:
#     ufw deny 5001  # allow only LAN access
